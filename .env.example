# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Canonical URL. Required on Vercel / production. Leave blank in local dev.
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth
# Create at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (only needed for the pricing Checkout flow)
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Matching recurring price IDs from the Stripe dashboard
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_STUDIO_ANNUAL=
# Enterprise is sales-assisted and has no self-serve price
